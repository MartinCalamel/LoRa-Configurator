#!/bin/bash

echo "Configuration de LoRa-Config..."

# 1. Vérifier si GCC est installé
if ! command -v gcc &> /dev/null
then
    echo "Erreur : gcc n'est pas installé. Installez-le pour compiler."
    exit 1
fi

# 2. Créer un dossier build si besoin
mkdir -p build

# 3. On peut imaginer ici vérifier des dépendances spécifiques
# (ex: bibliothèques pour l'UART sous Linux)

echo "Le système est prêt."
echo "Tapez 'make' pour compiler."